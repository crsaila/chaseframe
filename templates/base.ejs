<!-- templates/base.ejs - Base template that all other templates will extend -->
<!doctype html>
<html lang="en-CA">
<head>
  <title><%= page.meta.title ? page.meta.title + ' - ' : '' %><%= site.siteName %><%= page.isDraft ? ' (DRAFT)' : '' %><%= !page.isPublished ? ' (UNPUBLISHED)' : '' %></title>
  <meta charset="UTF-8">
  <meta name="author" content="<%= site.authorName %>">
  <meta name="description" content="<%= page.meta.description || site.siteDescription %>"> 
  <meta name="viewport" content="width=device-width, initial-scale=1">
<% if (page.meta.password) { %>
  <meta name="robots" content="noindex, nofollow">
<% } %>
  <%
  const _ogType = (page.meta.template === 'article') ? 'article' : 'website';
  const _ogTitle = page.meta.title ? page.meta.title + ' - ' + site.siteName : site.siteName;
  const _ogDesc = page.meta.description || site.siteDescription;
  const _ogUrl = site.siteUrl.replace(/\/$/, '') + page.path + (page.path && !page.path.endsWith('/') ? '.html' : '');
  %>
  <meta property="og:site_name" content="<%= site.siteName %>">
  <meta property="og:type" content="<%= _ogType %>">
  <meta property="og:title" content="<%= _ogTitle %>">
  <meta property="og:description" content="<%= _ogDesc %>">
  <meta property="og:url" content="<%= _ogUrl %>">
  <% if (_ogType === 'article') { %>
  <meta property="article:author" content="<%= site.authorName %>">
  <% if (page.meta.saved_date) { %><meta property="article:published_time" content="<%= new Date(page.meta.saved_date).toISOString() %>"><% } %>
  <% if (page.meta.updated_date) { %><meta property="article:modified_time" content="<%= new Date(page.meta.updated_date).toISOString() %>"><% } %>
  <% if (page.tags && page.tags.length) { page.tags.forEach(function(t) { %><meta property="article:tag" content="<%= t %>"><% }); } %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": "<%= (page.meta.title || '').replace(/"/g, '\\"') %>",
    "url": "<%= _ogUrl %>",
    "datePublished": "<%= page.meta.saved_date ? new Date(page.meta.saved_date).toISOString() : '' %>",
    <% if (page.meta.updated_date) { %>"dateModified": "<%= new Date(page.meta.updated_date).toISOString() %>",<% } %>
    "description": "<%= _ogDesc.replace(/"/g, '\\"') %>",
    <% if (page.tags && page.tags.length) { %>"keywords": "<%= page.tags.join(', ').replace(/"/g, '\\"') %>",<% } %>
    "author": {
      "@type": "Person",
      "name": "<%= site.authorName %>",
      "url": "<%= site.siteUrl %>"
    },
    "publisher": {
      "@type": "Person",
      "name": "<%= site.authorName %>",
      "url": "<%= site.siteUrl %>"
    }
  }
  </script>
  <% } %>
  <% if (site.siteStyle) { %><link rel="stylesheet" href="<%= site.siteStyle %>"><% } %>
  <% const _colFeedMatch = page.path && page.path.match(/^\/columns\/([^/]+)\//); %>
  <% if (_colFeedMatch) { %>
  <link rel="alternate" type="application/rss+xml" title="<%= site.siteName %> RSS Feed" href="/columns/<%= _colFeedMatch[1] %>/rss.xml">
  <% } %>
  <link rel="canonical" href="<%= _ogUrl %>">

  <% if (page.meta.customStyles) { %>
    <% page.meta.customStyles.forEach(function(stylesheet) { %>
      <link rel="stylesheet" href="/styles/<%= stylesheet %>">
    <% }); %>
  <% } %>
<script>
  document.documentElement.style.setProperty('--gradient-angle', Math.floor(Math.random()*360)+'deg');
  (function() {
    var seed = location.pathname.split('').reduce(function(a, c) { return (a * 31 + c.charCodeAt(0)) & 0xffff; }, 0);
    var svg = '<svg xmlns="http://www.w3.org/2000/svg" width="300" height="300"><filter id="t"><feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="4" seed="' + seed + '"/><feColorMatrix type="saturate" values="0"/></filter><rect width="300" height="300" filter="url(#t)" opacity="0.05"/></svg>';
    document.documentElement.style.backgroundImage = 'url("data:image/svg+xml,' + encodeURIComponent(svg) + '")';
  })();
  const risoColors = ['#ff4da6','#ffe800','#00a99d','#0047b3','#ff6c2f','#c8f442'];
  document.addEventListener('DOMContentLoaded', function() {
    // Prose links in articles — one riso colour per page, revealed on hover
    const risoColor = risoColors[Math.floor(Math.random()*risoColors.length)];
    document.querySelectorAll('.article-page a').forEach(function(a) {
      if (a.closest('footer.meta, .post-nav, .article-date') || a.hasAttribute('data-footnote-ref')) return;
      a.addEventListener('mouseenter', function() { this.style.color = risoColor; this.style.textDecorationColor = risoColor; });
      a.addEventListener('mouseleave', function() { this.style.color = ''; this.style.textDecorationColor = ''; });
    });
    // All links in main on non-article pages — random riso colour on hover
    if (!document.querySelector('.article-page')) {
      document.querySelectorAll('main a').forEach(function(a) {
        if (a.closest('.sort-options, .archive-navigation, footer.meta, .article-date')) return;
        const color = risoColors[Math.floor(Math.random()*risoColors.length)];
        a.addEventListener('mouseenter', function() { this.style.color = color; this.style.textDecorationColor = color; });
        a.addEventListener('mouseleave', function() { this.style.color = ''; this.style.textDecorationColor = ''; });
      });
    }
    // Sidebar links on article pages (aside is outside .article-page)
    document.querySelectorAll('.static-sidebar a').forEach(function(a) {
      const color = risoColors[Math.floor(Math.random()*risoColors.length)];
      a.addEventListener('mouseenter', function() { this.style.color = color; this.style.textDecorationColor = color; });
      a.addEventListener('mouseleave', function() { this.style.color = ''; this.style.textDecorationColor = ''; });
    });
  });
</script>
</head>

<body>
  <header>
    <h1><a href="/" title="Head to the homepage"><%= site.siteName %></a></h1>
    <hgroup>
      <h2 aria-hidden="true"><a href="<%= page.meta.sectionUrl || '/' %>" title="<%= page.meta.sectionTitle || 'Latest entries' %>"><%= page.meta.sectionName || 'Blog' %></a></h2>
      <% if (page.meta.sectionTagline) { %>
        <h3><%= page.meta.sectionTagline %></h3>
      <% } %>
      <% if (page.meta.subtitle) { %>
        <p><%= page.meta.subtitle %></p>
      <% } %>
    </hgroup>
    
    <!-- Navigation section with the new logic -->
    <nav aria-label="Site">
      <ul>
        <% 
        // Get navigation items
        const navItems = site.navigation || [];
        
        // Get current path
        const currentPath = page.path;
        
        // Function to detect if this is a top-level page in a section
        const isTopLevelPage = (navPath, pagePath) => {
          if (navPath === '/') return pagePath === '/' || pagePath === '/index';
          return pagePath === navPath || 
                 pagePath === navPath + '/' || 
                 pagePath === navPath + '/index';
        };
        
        // Function to detect if this is a sub-page in a section
        const isSubPage = (navPath, pagePath) => {
          // Root path '/' would match everything — exclude it
          if (navPath === '/') return false;

          // Not a match if it's not in this section at all
          if (!pagePath.startsWith(navPath)) return false;
          
          // Not a sub-page if it's the top level page
          if (isTopLevelPage(navPath, pagePath)) return false;
          
          // Otherwise it's a sub-page
          return true;
        };
        
        // Process each navigation item
        navItems.forEach(item => {
          // Determine if this is a top-level page or a sub-page
          const isTop = isTopLevelPage(item.path, currentPath);
          const isSub = isSubPage(item.path, currentPath);
          
          const isSection = item.section ? currentPath.startsWith(item.section) : false;
          const isActive = isTop || isSub || isSection;
        %>
          <li class="<%= isActive ? 'active' : '' %>">
            <a href="<%= item.path %>"<% if (item.abbr) { %> data-abbr="<%= item.abbr %>"<% } %><% if (item.title) { %> title="<%= item.title %>"<% } %><% if (isTop) { %> aria-current="page"<% } %>><%= item.label %></a>
          </li>
        <% }); %>
      </ul>
    </nav>
  </header>

  <main<% { const _cat = Array.isArray(page.meta && page.meta.category) ? page.meta.category[0] : (page.meta && page.meta.category); const _cls = _cat ? String(_cat).toLowerCase().replace(/\s+/g, '-') : (page.generated ? 'forme' : null); if (_cls) { %> class="<%= _cls %>"<% } } %>>
    <% if (page.isDraft || !page.isPublished) { %>
      <div class="status-indicators">
        <% if (!page.isPublished) { %>
          <p class="unpublished-notice">This content is not published to the live site.</p>
        <% } %>
        <% if (page.isDraft) { %>
          <p class="draft-notice">This is a draft.</p>
        <% } %>
      </div>
    <% } %>

    <!-- Content section - this is where page-specific content gets inserted -->
    <% if (typeof content !== 'undefined') { %>
		<% if (page.meta.password) { %>
		  <div id="password-gate">
		    <label for="page-password">Password required</label>
		    <input type="password" id="page-password" autofocus>
		    <button id="page-unlock">Enter</button>
		  </div>
		  <div id="protected-content" hidden>
		    <%- content %>
		  </div>
		  <script>
		    document.getElementById('page-unlock').addEventListener('click', function() {
		      if (document.getElementById('page-password').value === '<%= page.meta.password %>') {
		        document.getElementById('protected-content').hidden = false;
		        document.getElementById('password-gate').hidden = true;
		      }
		    });
		  </script>
		<% } else { %>
		  <%- content %>
		<% } %>
    <% } else { %>
        <!-- Default content or placeholder -->
        <p>No content available.</p>
    <% } %>

  </main>
  
  <footer>
    <address><p id="colophon"><% if (site.copyright && site.copyright.licenseUrl) { %><a href="<%= site.copyright.licenseUrl %>" rel="license"><%= site.copyright.license %></a> <% } %><time datetime="<%= site.copyright.startYear %>"><%= site.copyright.startYear %></time>&#8201;&#8211;&#8201;<time datetime="<%= site.buildYear || new Date().getFullYear() %>"><%= site.buildYear || new Date().getFullYear() %></time><% if (site.authorName) { %>&#8194;&#183;&#8194;<a href="<%= site.siteUrl %>about/" rel="author"><%= site.authorName %></a><% } %><% if (site.location) { %>&#8194;&#183;&#8194;<% if (site.locationUrl) { %><a href="<%= site.locationUrl %>"><%= site.location %></a><% } else { %><%= site.location %><% } %><% } %></p></address>
  </footer>
</body>
</html>