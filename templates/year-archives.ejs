<!-- templates/year-archives.ejs - Template for yearly archive pages -->
<%- include('./partials/helpers') %>
<%- include('./partials/helper-functions') %>
<%
  // Derive section prefix from page path (e.g. /columns/blog/2025 → /columns/blog)
  const yearArchiveColMatch = page.path.match(/^(\/columns\/[^/]+)/);
  const yearArchiveBase = yearArchiveColMatch ? yearArchiveColMatch[1] : '';
%>

<section class="year-archive-page">
  <%- include('./partials/page-header', {
    title: `<a href="${yearArchiveBase}/">${(site.columns[page.meta.columnName] && site.columns[page.meta.columnName].title) || page.meta.columnName || 'Archive'}</a> Archive`,
    description: `All posts from <strong><time datetime="${page.meta.year}">${page.meta.year}</time></strong>`
  }) %>
  
  <%
    const _yearCount = page.meta.months ? page.meta.months.length : 0;
    const _yearSpacing = listSpacingFn(_yearCount);
  %>
  <section class="year-archive" style="margin-top: <%= _yearSpacing %>rem; margin-bottom: <%= _yearSpacing %>rem;">
    <% if (!page.meta.months || page.meta.months.length === 0) { %>
      <%- include('./partials/empty-state', { 
        message: 'No content found for this year.'
      }) %>
    <% } else { %>
      <% page.meta.months.forEach(month => { 
        const monthName = getMonthNameFn(month.month);
      %>
        <div class="month-container">
          <h2 class="month-heading">
            <a href="<%= yearArchiveBase %>/<%= page.meta.year %>/<%= month.month.padStart(2, '0') %>/"><time datetime="<%= page.meta.year %>-<%= month.month.padStart(2, '0') %>"><%= monthName %></time></a>
          </h2>
          <div class="post-list">
            <% if (month.posts && month.posts.length > 0) { %>
              <% month.posts.forEach(post => { 
                const postDate = new Date(post.meta.saved_date);
                const day = postDate.getDate();
              %>
                <div class="post-item">
                  <span class="post-date">
                    <a href="<%= yearArchiveBase %>/<%= page.meta.year %>/<%= month.month.padStart(2, '0') %>/<%= day.toString().padStart(2, '0') %>/">
                      <time datetime="<%= page.meta.year %>-<%= month.month.padStart(2, '0') %>-<%= day.toString().padStart(2, '0') %>"><%= day %></time>
                    </a>
                  </span>
                  <a href="<%= post.path %>.html" rel="bookmark"><%= post.meta.title %></a>
                </div>
              <% }); %>
            <% } %>
          </div>
        </div>
      <% }); %>
    <% } %>
  </section>
  <%- include('./partials/archive-navigation', {
    prevLink: page.meta.prevYear ? { url: `${yearArchiveBase}/${page.meta.prevYear}/`, text: page.meta.prevYear } : null,
    upLink: { url: `${yearArchiveBase}/archives/`, text: 'All Years' },
    nextLink: page.meta.nextYear ? { url: `${yearArchiveBase}/${page.meta.nextYear}/`, text: page.meta.nextYear } : null
  }) %>
</section>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "<%= site.siteUrl %>"},
    {"@type": "ListItem", "position": 2, "name": "Archive", "item": "<%= site.siteUrl.replace(/\/$/, '') + yearArchiveBase %>/archives/"},
    {"@type": "ListItem", "position": 3, "name": "<%= page.meta.year %>", "item": "<%= site.siteUrl.replace(/\/$/, '') + yearArchiveBase %>/<%= page.meta.year %>/"}
  ]
}
</script>